exports[`<ClaimsDashboardGuidance /> @renders when overdue claim 1`] = `
<div
  aria-label="info message"
  class="govuk-warning-text acc-message acc-message__info"
  data-qa="guidance-message"
  data-qa-type="info"
  style="border-color: #1d70b8;"
>
  <div
    class="govuk-visually-hidden"
    data-qa="guidance-message-assistive"
  >
    Info
  </div>
  <div
    class="govuk-body"
    data-qa="guidance-message-content"
  >
    Deadline past. Too late. Email 
    <a
      class="govuk-link govuk-!-font-size-19"
      href="mailto:webmaster@example.com"
    >
      webmaster
      <wbr />
      @
      example.com
    </a>
     for more information.
  </div>
</div>
`;
